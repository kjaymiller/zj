# Remote zellij web sessions, one URL per line. Lines starting with # are ignored.
# Copy to ${XDG_CONFIG_HOME:-~/.config}/zj/remotes (or set $ZJ_REMOTES_FILE).
#
# Each URL is offered in the picker and attached via:
#   zellij attach <url> --token <token> --remember [--ca-cert <ZJ_CA_CERT>]

https://zellij.kjaymiller.dev/homelab
