#!/usr/bin/env bash
# zj — fuzzy-pick a zellij session, a zoxide directory, or a remote web session.
#
# Sources merged into the picker:
#   - active local zellij sessions          (cyan)
#   - zoxide-tracked directories            (blue)
#   - configured remote web sessions        (magenta)  e.g. https://zellij.kjaymiller.dev/homelab
#   - GitHub repos for configured owners    (green)    shown as gh:owner/repo
#
# Remote sessions are attached with `zellij attach <url> --token ...`. The token
# is resolved via fnox (which can serve it from 1Password); if fnox has no value
# you are prompted, and may cache it back into fnox.
#
# Config (all optional, via env):
#   ZJ_REMOTES_FILE  path to a newline-separated list of remote session URLs
#                    (default: ${XDG_CONFIG_HOME:-~/.config}/zj/remotes)
#   ZJ_TOKEN_KEY     fnox secret name holding the remote token
#                    (default: ZELLIJ_WEB_TOKEN)
#   ZJ_CA_CERT       path to a CA cert (PEM) for verifying the remote server.
#                    If set and the file exists, passed as `--ca-cert`.
#   ZJ_ORGS_FILE     path to a newline-separated list of GitHub owners/orgs
#                    (e.g. `kjaymiller`, `zellij-org`). Their repos are fetched
#                    in a single GitHub GraphQL call and shown with a `gh:`
#                    indicator; selecting one clones it (if needed) then opens a
#                    session there.
#                    (default: ${XDG_CONFIG_HOME:-~/.config}/zj/orgs)
#   ZJ_REPOS_DIR     base directory repos are cloned into
#                    (default: ~/projects)
#   ZJ_GH_LIMIT      max repos fetched per owner (default: 200)
#   ZJ_GH_CACHE_TTL  minutes to cache the GraphQL results so the picker stays
#                    instant (default: 60; 0 disables the cache)
#   ZJ_GH_TOKEN_KEY  fnox secret name holding a GitHub token for the GraphQL
#                    query. If fnox has a value it's used; otherwise gh falls
#                    back to its own login / $GH_TOKEN. (default: GH_API_TOKEN)

set -uo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/zj"
REMOTES_FILE="${ZJ_REMOTES_FILE:-$CONFIG_DIR/remotes}"
TOKEN_KEY="${ZJ_TOKEN_KEY:-ZELLIJ_WEB_TOKEN}"
CA_CERT="${ZJ_CA_CERT:-}"
ORGS_FILE="${ZJ_ORGS_FILE:-$CONFIG_DIR/orgs}"
REPOS_DIR="${ZJ_REPOS_DIR:-$HOME/projects}"
GH_LIMIT="${ZJ_GH_LIMIT:-200}"
GH_CACHE_TTL="${ZJ_GH_CACHE_TTL:-60}"
GH_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/zj/repos"
GH_TOKEN_KEY="${ZJ_GH_TOKEN_KEY:-GH_API_TOKEN}"

# --- gather sources ------------------------------------------------------------

list_local_sessions() {
  zellij list-sessions -sn 2>/dev/null
}

list_remotes() {
  [ -f "$REMOTES_FILE" ] || return 0
  # Skip blank lines and comments (#).
  grep -vE '^\s*(#|$)' "$REMOTES_FILE" 2>/dev/null
}

list_orgs() {
  [ -f "$ORGS_FILE" ] || return 0
  # Skip blank lines and comments (#).
  grep -vE '^\s*(#|$)' "$ORGS_FILE" 2>/dev/null
}

# List owner/repo slugs for every configured owner via gh, cached for
# ZJ_GH_CACHE_TTL minutes so the picker doesn't block on the network.
list_repos() {
  command -v gh >/dev/null 2>&1 || return 0

  local owners
  owners="$(list_orgs)"
  [ -z "$owners" ] && return 0

  # Serve from cache while it's still fresh.
  if [ "$GH_CACHE_TTL" -gt 0 ] && [ -f "$GH_CACHE" ] \
     && [ -n "$(find "$GH_CACHE" -mmin "-$GH_CACHE_TTL" 2>/dev/null)" ]; then
    cat "$GH_CACHE"
    return 0
  fi

  # Refresh: one GraphQL call fetches every owner's repos at once via aliased
  # sub-queries, instead of a REST call per owner. GraphQL caps `first` at 100.
  local first="$GH_LIMIT"
  [ "$first" -gt 100 ] && first=100

  local query="query {" i=0 owner
  while IFS= read -r owner; do
    [ -z "$owner" ] && continue
    query+=" o${i}: repositoryOwner(login: \"${owner}\")"
    query+=" { repositories(first: ${first}, ownerAffiliations: OWNER) { nodes { nameWithOwner } } }"
    i=$((i + 1))
  done <<EOF
$owners
EOF
  query+=" }"

  # Prefer a GitHub token stashed in fnox (1Password-backed, like the remote
  # token); otherwise let gh use its own login / $GH_TOKEN.
  local gh_token
  gh_token="$(fnox get "$GH_TOKEN_KEY" 2>/dev/null || true)"

  # repositoryOwner is null for an unknown login; select(. != null) drops those.
  local jq_filter='[.data[] | select(. != null) | .repositories.nodes[].nameWithOwner] | .[]'
  local fetched
  if [ -n "$gh_token" ]; then
    fetched="$(GH_TOKEN="$gh_token" gh api graphql -f query="$query" --jq "$jq_filter" 2>/dev/null)"
  else
    fetched="$(gh api graphql -f query="$query" --jq "$jq_filter" 2>/dev/null)"
  fi

  # Only overwrite the cache on a non-empty result, so a transient network or
  # auth failure falls back to the last good list instead of an empty picker.
  if [ -n "$fetched" ]; then
    mkdir -p "$(dirname "$GH_CACHE")"
    printf '%s\n' "$fetched" >"$GH_CACHE"
    printf '%s\n' "$fetched"
  elif [ -f "$GH_CACHE" ]; then
    cat "$GH_CACHE"
  fi
}

raw_target=$({
  list_local_sessions | awk 'NF {printf "\033[36m%s\033[0m\n", $0}'
  list_remotes          | awk 'NF {printf "\033[35m%s\033[0m\n", $0}'
  zoxide query -l       | awk 'NF {printf "\033[34m%s\033[0m\n", $0}'
  list_repos            | awk 'NF {printf "\033[32mgh:%s\033[0m\n", $0}'
} | awk '!seen[$0]++' | gum filter --no-strip-ansi --placeholder 'Pick a session, project, remote, or repo...')

# Exit if nothing was selected (user pressed Esc).
[ -z "$raw_target" ] && exit 0

# Strip ANSI codes from the selection.
target=$(printf '%s' "$raw_target" | awk '{gsub(/\033\[[0-9;]*m/, ""); print}')

# --- token handling (remote only) ---------------------------------------------

get_token() {
  local token
  token="$(fnox get "$TOKEN_KEY" 2>/dev/null)"
  if [ -n "$token" ]; then
    printf '%s' "$token"
    return 0
  fi

  token="$(gum input --password --placeholder "Token for $TOKEN_KEY")"
  [ -z "$token" ] && return 1

  if gum confirm "Cache this token via fnox ($TOKEN_KEY)?"; then
    if printf '%s' "$token" | fnox set "$TOKEN_KEY" >/dev/null 2>&1; then
      echo "Cached token in fnox as $TOKEN_KEY." >&2
    else
      echo "Could not cache token (is fnox.toml configured?). Continuing." >&2
    fi
  fi

  printf '%s' "$token"
}

attach_remote() {
  local url="$1" token
  token="$(get_token)" || { echo "No token provided; aborting." >&2; exit 1; }

  local args=("$url" --token "$token" --remember)
  if [ -n "$CA_CERT" ] && [ -f "$CA_CERT" ]; then
    args+=(--ca-cert "$CA_CERT")
  fi

  exec zellij attach "${args[@]}"
}

# --- session / repo helpers ---------------------------------------------------

# Open (or hot-switch to) a zellij session rooted at a directory.
start_session_in_dir() {
  local dir="$1" session_name
  session_name="$(basename "$dir")"
  if [[ -n "${ZELLIJ:-}" ]]; then
    local dir_abs
    dir_abs="$(cd "$dir" && pwd)"
    # Bypass the zellij-switch plugin's flawed cwd handling by explicitly
    # creating the session in the background from the correct directory first.
    (cd "$dir_abs" && zellij attach -c "$session_name" -b)
    zellij pipe --plugin "https://github.com/mostafaqanbaryan/zellij-switch/releases/download/0.2.1/zellij-switch.wasm" -- "--session \"$session_name\""
  else
    exec zellij attach -c "$session_name" options --default-cwd "$dir"
  fi
}

# Clone a GitHub repo (if not already present), then open a session in it.
# Accepts an owner/repo slug or a full git URL.
clone_and_start() {
  local repo="$1" name dest
  name="$(basename "${repo%.git}")"
  dest="$REPOS_DIR/$name"

  if [ ! -d "$dest" ]; then
    mkdir -p "$REPOS_DIR"
    echo "Cloning $repo into $dest ..." >&2
    if [[ "$repo" != *://* && "$repo" != git@* ]]; then
      # owner/repo slug — prefer gh (handles auth/SSH), else fall back to https.
      if command -v gh >/dev/null 2>&1; then
        gh repo clone "$repo" "$dest" || { echo "Clone failed: $repo" >&2; exit 1; }
      else
        git clone "https://github.com/$repo.git" "$dest" || { echo "Clone failed: $repo" >&2; exit 1; }
      fi
    else
      git clone "$repo" "$dest" || { echo "Clone failed: $repo" >&2; exit 1; }
    fi
  fi

  start_session_in_dir "$dest"
}

# --- dispatch ------------------------------------------------------------------

if [[ "$target" == gh:* ]]; then
  clone_and_start "${target#gh:}"

elif [[ "$target" =~ ^https?:// ]]; then
  attach_remote "$target"

elif list_local_sessions | grep -Fxq "$target"; then
  if [[ -n "${ZELLIJ:-}" ]]; then
    zellij pipe --plugin "https://github.com/mostafaqanbaryan/zellij-switch/releases/download/0.2.1/zellij-switch.wasm" -- "--session \"$target\""
  else
    exec zellij attach "$target"
  fi

elif [ -d "$target" ]; then
  start_session_in_dir "$target"

else
  echo "Error: '$target' is neither a repo, a remote URL, an active session, nor a valid directory." >&2
  exit 1
fi
